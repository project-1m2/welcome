<RCC>
    <qresource prefix="/icons">
        <!-- Window controls -->
        <file alias="window-close.svg">icons/symbolic/window-close.svg</file>
        <file alias="window-minimize.svg">icons/symbolic/window-minimize.svg</file>
        <file alias="window-maximize.svg">icons/symbolic/window-maximize.svg</file>
        <file alias="window-restore.svg">icons/symbolic/window-restore.svg</file>
        
        <!-- Navigation -->
        <file alias="arrow-right.svg">icons/symbolic/arrow-right.svg</file>
        <file alias="go-next.svg">icons/symbolic/go-next.svg</file>
        <file alias="go-previous.svg">icons/symbolic/go-previous.svg</file>
        
        <!-- System -->
        <file alias="system-software-update.svg">icons/symbolic/system-software-update.svg</file>
        <file alias="system-users.svg">icons/symbolic/system-users.svg</file>
        <file alias="security-high.svg">icons/symbolic/security-high.svg</file>
        <file alias="folder-sync.svg">icons/symbolic/folder-sync.svg</file>
        <file alias="cpu.svg">icons/symbolic/cpu.svg</file>
        <file alias="memory.svg">icons/symbolic/memory.svg</file>
        <file alias="clock.svg">icons/symbolic/clock.svg</file>
        <file alias="configure.svg">icons/symbolic/configure.svg</file>
        
        <!-- Preferences -->
        <file alias="preferences-desktop-theme.svg">icons/symbolic/preferences-desktop-theme.svg</file>
        <file alias="preferences-desktop-font.svg">icons/symbolic/preferences-desktop-font.svg</file>
        <file alias="preferences-desktop-icons.svg">icons/symbolic/preferences-desktop-icons.svg</file>
        <file alias="preferences-desktop-wallpaper.svg">icons/symbolic/preferences-desktop-wallpaper.svg</file>
        <file alias="preferences-system-activities.svg">icons/symbolic/preferences-system-activities.svg</file>
        
        <!-- Applications -->
        <file alias="application-x-executable.svg">icons/symbolic/application-x-executable.svg</file>
        <file alias="applications-office.svg">icons/symbolic/applications-office.svg</file>
        <file alias="applications-versioncontrol.svg">icons/symbolic/applications-versioncontrol.svg</file>
        <file alias="applications-chat.svg">icons/symbolic/applications-chat.svg</file>
