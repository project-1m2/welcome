        <file alias="google-chrome.svg">icons/symbolic/google-chrome.svg</file>
        <file alias="brave-browser.svg">icons/symbolic/brave-browser.svg</file>
        <file alias="microsoft-edge.svg">icons/symbolic/microsoft-edge.svg</file>
        <file alias="opera.svg">icons/symbolic/opera.svg</file>
        <file alias="tor-browser.png">icons/symbolic/tor-browser.png</file>
        
