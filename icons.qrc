        <file alias="wps-office2019-kprometheus.svg">icons/symbolic/wps-office2019-kprometheus.svg</file>
        <file alias="ms-office.svg">icons/symbolic/ms-office.svg</file>
        <file alias="google-docs.svg">icons/symbolic/google-docs.svg</file>
        
        <!-- AI Apps -->
