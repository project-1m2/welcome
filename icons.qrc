        <file alias="maritalk.png">icons/symbolic/maritalk.png</file>
        <file alias="leonardo-ai.svg">icons/symbolic/leonardo-ai.svg</file>
        
        <!-- Community (PNG for Qt compatibility) -->
        <file alias="github.png">icons/symbolic/github.png</file>
        <file alias="fork.png">icons/symbolic/fork.png</file>
        <file alias="telegram.png">icons/symbolic/telegram.png</file>
        <file alias="youtube.png">icons/symbolic/youtube.png</file>
        <file alias="instagram.png">icons/symbolic/instagram.png</file>
        <file alias="documentation.png">icons/symbolic/documentation.png</file>
